# Procedures (275 rows)
SPARQL
PREFIX skos:  <http://www.w3.org/2004/02/skos/core#>
SELECT ?query
WHERE {
    GRAPH <http://w3id.org/glosis/model/procedure> {
        ?uri a skos:Concept .
        ?uri skos:prefLabel ?label .
        OPTIONAL { ?uri skos:notation ?notation }
        OPTIONAL { ?uri skos:definition ?definition }
        OPTIONAL { ?uri skos:broader ?broader }
        OPTIONAL { ?uri skos:scopeNote ?ref   FILTER(isURI(?ref)) }
        OPTIONAL { ?uri skos:scopeNote ?cit   FILTER(isLiteral(?cit)) }
    }
    BIND(UCASE(COALESCE(STR(?notation), '')) AS ?proc_id)
    BIND(REPLACE(COALESCE(STR(?definition), ''), "'", "''") AS ?def)
    BIND(COALESCE(STR(?ref), '') AS ?reference)
    BIND(REPLACE(COALESCE(STR(?cit), ''), "'", "''") AS ?citation)
    BIND(CONCAT(
        'INSERT INTO soil_data.procedure_num (uri, procedure_num_id, broader_id, procedure_name, reference, citation) VALUES (\'',
        STR(?uri), '\', \'', ?proc_id, '\', ',
        '(SELECT procedure_num_id FROM soil_data.procedure_num WHERE uri LIKE \'', COALESCE(STR(?broader), ''), '\'), \'',
        ?def, '\', \'', ?reference, '\', \'', ?citation,
        '\') ON CONFLICT DO NOTHING;'
    ) AS ?query)
};