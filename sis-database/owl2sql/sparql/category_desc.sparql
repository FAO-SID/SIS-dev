# Code-list values for descriptive observations Element (373 rows)
SPARQL
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl:   <http://www.w3.org/2002/07/owl#>
PREFIX sosa:  <http://www.w3.org/ns/sosa/>
PREFIX skos:  <http://www.w3.org/2004/02/skos/core#>
PREFIX glosis_lh: <http://w3id.org/glosis/model/layerhorizon/>
SELECT DISTINCT ?query
WHERE {
    ?obs rdfs:subClassOf sosa:Observation .
    ?obs rdfs:subClassOf ?rest_f .
    ?obs rdfs:subClassOf ?rest_r .
    ?rest_f owl:onProperty sosa:hasFeatureOfInterest .
    ?rest_f owl:allValuesFrom ?u .
    ?u owl:unionOf ?set .
    ?set rdf:rest*/rdf:first ?elements .
    FILTER (glosis_lh:GL_Layer IN (?elements)) .
    ?rest_r owl:onProperty sosa:hasResult .
    ?rest_r owl:someValuesFrom ?code_list .
    ?value a ?code_list .
    ?value skos:prefLabel ?l .
    OPTIONAL { ?value skos:definition ?definition }
    OPTIONAL { ?value skos:notation ?notation }
    BIND(STRAFTER(STR(?value), 'http://w3id.org/glosis/model/codelists/') AS ?code_id)
    BIND(REPLACE(STR(?l), "'", "''") AS ?label)
    BIND(REPLACE(COALESCE(STR(?definition), ''), "'", "''") AS ?def)
    BIND(COALESCE(STR(?notation), '') AS ?not)
    BIND(CONCAT(
        'INSERT INTO soil_data.category_desc (category_name, category_desc_id, uri, definition, notation) VALUES (\'',
        ?label, '\', \'', ?code_id, '\', \'', STR(?value), '\', \'', ?def, '\', \'', ?not, '\') ON CONFLICT DO NOTHING;'
    ) AS ?query)
};