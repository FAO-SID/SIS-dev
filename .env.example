# SIS deployment configuration. Copy this file to .env and fill in real values,
# OR run deploy.sh which will generate .env with random secrets if missing.
# NEVER commit a populated .env to git.

# Database configuration
POSTGRES_HOST=sis-database
POSTGRES_PORT=5432
POSTGRES_DB=sis

# `sis` is the application superuser used by sis-api and sis-metadata.
# Generate with: openssl rand -base64 32
POSTGRES_USER=sis
POSTGRES_PASSWORD=__GENERATE_ME__

# Read-only DB role used exclusively by sis-api-glosis (only has SELECT on the
# federation views — see init.sql). Generate with: openssl rand -base64 32
POSTGRES_GLOSIS_USER=sis_glosis
POSTGRES_GLOSIS_PASSWORD=__GENERATE_ME__

# JWT signing key for sis-api. MUST be unique per deployment — sharing this key
# across nodes lets a token from one node authenticate against another.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=__GENERATE_ME__
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Public read-only API key embedded in the sis-web-mapping JS bundle. Treat as
# a soft access token: it appears in DevTools for any visitor and only unlocks
# read-only data endpoints. Rotate per deployment.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEB_MAPPING_API_KEY=__GENERATE_ME__
